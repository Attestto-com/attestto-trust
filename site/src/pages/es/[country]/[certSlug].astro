---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import RoleBadge from '../../../components/RoleBadge.astro';
import ValidityChip from '../../../components/ValidityChip.astro';
import CopyValue from '../../../components/CopyValue.astro';
import { COUNTRIES, loadCountry, chainOf, pemHref } from '../../../lib/trust.js';
import { TRANSLATIONS, getCountryName } from '../../../lib/i18n.js';

export function getStaticPaths() {
  const paths = [];
  for (const c of COUNTRIES) {
    const data = loadCountry(c.code);
    for (const cert of data.certs) {
      paths.push({
        params: { country: c.code, certSlug: cert.slug },
        props: { code: c.code, slug: cert.slug },
      });
    }
  }
  return paths;
}

const { code, slug } = Astro.props;
const data = loadCountry(code);
const cert = data.certs.find((c) => c.slug === slug);
const chain = chainOf(cert);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const lang = 'es';
const t = TRANSLATIONS[lang];

const fmt = (iso) =>
  new Date(iso).toLocaleString('es-ES', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    timeZoneName: 'short',
  });
const selfSigned = cert.issuer === cert.subject;
---
<BaseLayout
  title={cert.subjectDisplay}
  description={`Detalles del certificado para ${cert.subjectDisplay} (PKI de ${getCountryName(code, lang)}). SHA-256, validez, cadena de emisor y descarga de .pem.`}
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={`${base}/es/`}>{t.certNavHome}</a></li>
      <li><a href={`${base}/es/${code}`}>{getCountryName(code, lang)}</a></li>
      <li aria-current="page">{cert.subjectDisplay}</li>
    </ol>
  </nav>

  <header class="detail-head">
    <div class="detail-head__badges">
      <RoleBadge role={cert.role} />
      <ValidityChip validity={cert.validity} />
    </div>
    <h1>{cert.subjectDisplay}</h1>
    <p class="detail-head__sub">{getCountryName(code, lang)} · {t.countryPublishedBy} {data.authority?.name}</p>
    <div class="detail-head__actions">
      <a class="btn btn--primary" href={pemHref(code, cert.file)} download>{t.certDownloadPem}</a>
      <a class="btn" href={`${base}/es/${code}`}>{t.certBackTo.replace('{0}', getCountryName(code, lang))}</a>
    </div>
  </header>

  {cert.orphan && (
    <p class="notice">
      {t.certOrphanNotice.replace('{0}', cert.issuerDisplay)}
    </p>
  )}

  <section class="panel" aria-labelledby="chain-h">
    <h2 id="chain-h">{t.certChainH2}</h2>
    <p class="panel__hint">{t.certChainHint}</p>
    <ol class="chain">
      {chain.map((node, i) => (
        <li class={`chain__item${node.slug === cert.slug ? ' chain__item--current' : ''}`}>
          <span class="chain__depth" aria-hidden="true">{i === 0 ? t.certChainRoot : `L${i}`}</span>
          <div class="chain__body">
            {node.slug === cert.slug ? (
              <strong>{node.subjectDisplay}</strong>
            ) : (
              <a href={`${base}/es/${code}/${node.slug}`}>{node.subjectDisplay}</a>
            )}
            <RoleBadge role={node.role} />
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="panel" aria-labelledby="fields-h">
    <h2 id="fields-h">{t.certFieldsH2}</h2>
    <dl class="kv">
      <dt>{t.certFieldSubject}</dt>
      <dd>{cert.subjectDisplay}</dd>

      <dt>{t.certFieldIssuer}</dt>
      <dd>{selfSigned ? `${cert.issuerDisplay} ${t.certFieldSelfSignedRoot}` : cert.issuerDisplay}</dd>

      <dt>{t.certFieldRole}</dt>
      <dd><RoleBadge role={cert.role} /></dd>

      {cert.keyAlgorithm && (<Fragment>
      <dt>Algoritmo de clave</dt>
      <dd class="mono">{cert.keyAlgorithm}</dd>
      </Fragment>)}

      <dt>{t.certFieldValidity}</dt>
      <dd><ValidityChip validity={cert.validity} /></dd>

      <dt>{t.certFieldValidFrom}</dt>
      <dd class="mono"><time datetime={cert.validFrom}>{fmt(cert.validFrom)}</time></dd>

      <dt>{t.certFieldValidTo}</dt>
      <dd class="mono"><time datetime={cert.validTo}>{fmt(cert.validTo)}</time></dd>

      <dt>{t.certFieldSerial}</dt>
      <dd><CopyValue value={cert.serialNumber} label={t.certFieldSerial.toLowerCase()} /></dd>

      <dt>{t.certFieldSha256}</dt>
      <dd><CopyValue value={cert.sha256} label={t.certFieldSha256.toLowerCase()} /></dd>

      {cert.crlUrls?.length > 0 && (<Fragment>
      <dt>CRL</dt>
      <dd>{cert.crlUrls.map((u) => <div><a href={u} rel="noopener noreferrer" target="_blank" class="mono endpoint" title="Lista de revocación de certificados (abre en una pestaña nueva)">{u}</a></div>)}</dd>
      </Fragment>)}

      {cert.ocspUrls?.length > 0 && (<Fragment>
      <dt>OCSP</dt>
      <dd>{cert.ocspUrls.map((u) => <div><a href={u} rel="noopener noreferrer" target="_blank" class="mono endpoint" title="Endpoint del respondedor OCSP (abre en una pestaña nueva)">{u}</a></div>)}</dd>
      </Fragment>)}

      <dt>{t.certFieldFile}</dt>
      <dd><code class="mono">{cert.file}</code></dd>
    </dl>
  </section>

  <section class="panel panel--muted" aria-labelledby="prov-h">
    <h2 id="prov-h">{t.certProvenanceH2}</h2>
    <p set:html={t.certProvenanceText.replace('{0}', data.authority?.url ? `<a href="${data.authority?.url}" rel="noopener">${data.authority?.name}</a>` : data.authority?.name)} />
    <p class="panel__hint">
      {t.certProvenanceGenerated.replace('{0}', fmt(data.generatedAt))}
    </p>
  </section>
</BaseLayout>

<style>
  .detail-head { margin-bottom: var(--space-6); }
  .detail-head__badges { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-bottom: var(--space-3); }
  .detail-head h1 { margin: 0 0 var(--space-2); word-break: break-word; }
  .detail-head__sub { color: var(--color-text-muted); font-size: var(--text-sm); margin-bottom: var(--space-4); }
  .detail-head__actions { display: flex; gap: var(--space-2); flex-wrap: wrap; }

  .panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
  }
  .panel--muted { background: var(--color-surface-alt); }
  .panel h2 { margin-top: 0; font-size: var(--text-lg); }
  .panel__hint { color: var(--color-text-muted); font-size: var(--text-sm); }

  .chain { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-2); }
  .chain__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }
  .chain__item--current { border-color: var(--color-accent); background: var(--color-accent-soft); }
  .chain__depth {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-subtle);
    min-width: 2.5rem;
  }
  .chain__body { display: flex; align-items: center; gap: var(--space-3); flex-wrap: wrap; }
</style>
