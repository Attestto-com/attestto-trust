---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadGlobalAnchors } from '../../lib/anchors.js';
import { TRANSLATIONS } from '../../lib/i18n.js';

const lang = 'es';
const t = TRANSLATIONS[lang];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const anchor = loadGlobalAnchors().find((a) => a.id === 'gleif-vlei');
---
<BaseLayout title={`${anchor.name} — ${t.homeGlobalH2}`} description={anchor.notes}>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={`${base}/es/`}>{t.countryNavHome}</a></li>
      <li aria-current="page">{anchor.name}</li>
    </ol>
  </nav>
  <header class="anchor-head">
    <img src="/gleif-logo.svg" alt="GLEIF logo" width="40" height="40" style="object-fit:contain;flex-shrink:0" />
    <div>
      <h1>{anchor.name}</h1>
      <p class="anchor-head__authority">{t.countryPublishedBy} <a href={anchor.authority.url} rel="noopener noreferrer" target="_blank">{anchor.authority.name}</a></p>
    </div>
  </header>

  <section class="pki-about" aria-label="Acerca de esta ancla">
    <dl class="pki-about__grid">
      <div><dt>{t.globalAnchorRootAid}</dt><dd><code>{anchor.rootAid.aid}</code></dd></div>
      {anchor.rootAid.keyStateDigest && <div><dt>Estado de clave</dt><dd><code>{anchor.rootAid.keyStateDigest}</code></dd></div>}
      <div><dt>{t.globalAnchorQvis}</dt><dd>{anchor.qviCount}</dd></div>
      <div><dt>Modelo</dt><dd>{anchor.technology.keyModel}</dd></div>
      <div><dt>Credencial</dt><dd>{anchor.technology.credentialFormat}</dd></div>
      <div><dt>Cadena</dt><dd>{anchor.technology.chain}</dd></div>
    </dl>
    <p class="pki-about__notes">{anchor.notes}</p>
    <ul class="pki-about__links">
      {anchor.relatedLinks.map((l) => <li><a href={l.url} rel="noopener noreferrer" target="_blank">{l.label} ↗</a></li>)}
    </ul>
  </section>

  <section aria-label="Emisores vLEI cualificados">
    <h2>{t.globalAnchorQvis} ({anchor.qviCount})</h2>
    <table class="qvi-table">
      <thead><tr><th>Nombre</th><th>LEI</th><th>AID</th><th>Estado</th></tr></thead>
      <tbody>
        {anchor.qvis.map((q) => (
          <tr><td>{q.name}</td><td><code>{q.lei}</code></td><td>{q.aid ? <code>{q.aid}</code> : '—'}</td><td>{q.status}</td></tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>

<style>
  .anchor-head { display: flex; gap: var(--space-4); align-items: center; margin-bottom: var(--space-6); padding-bottom: var(--space-5); border-bottom: 1px solid var(--color-border); }
  .anchor-head h1 { margin: 0; }
  .anchor-head__authority { margin: var(--space-1) 0 0; color: var(--color-text-muted); font-size: var(--text-sm); }
  .pki-about { margin: var(--space-4) 0; padding: var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); background: var(--color-surface); }
  .pki-about__grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: var(--space-4) var(--space-6); margin: 0; }
  .pki-about__grid dt { font-size: var(--text-xs); color: var(--color-text-subtle); text-transform: uppercase; letter-spacing: 0.03em; }
  .pki-about__grid dd { margin: 2px 0 0; font-size: var(--text-sm); font-weight: 500; }
  @media (max-width: 560px) { .pki-about__grid { grid-template-columns: 1fr; } }
  .pki-about__grid dd code { font-size: var(--text-xs); word-break: break-all; font-weight: 400; }
  .pki-about__notes { margin: var(--space-3) 0 0; color: var(--color-text-muted); font-size: var(--text-sm); line-height: 1.5; }
  .pki-about__links { margin: var(--space-3) 0 0; padding: 0; list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .pki-about__links a { font-size: var(--text-sm); }
  .qvi-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .qvi-table th, .qvi-table td { text-align: left; padding: var(--space-2) var(--space-3); border-bottom: 1px solid var(--color-border); }
  .qvi-table code { font-size: var(--text-xs); word-break: break-all; }
</style>
