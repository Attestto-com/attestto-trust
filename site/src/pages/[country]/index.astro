---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TreeNode from '../../components/TreeNode.astro';
import AboutPanel from '../../components/AboutPanel.astro';
import { COUNTRIES, loadCountry } from '../../lib/trust.js';
import { TRANSLATIONS, getCountryName } from '../../lib/i18n.js';

export function getStaticPaths() {
  return COUNTRIES.map((c) => ({ params: { country: c.code } }));
}

const { country } = Astro.params;
const data = loadCountry(country);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const lang = 'en';
const t = TRANSLATIONS[lang];

const fmtDate = (iso) =>
  new Date(iso).toLocaleDateString('en-CA', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  });

const rootCount = data.roots.filter((c) => c.role === 'root' || c.issuer === c.subject).length;
const intermediateCount = data.certs.filter((c) => c.role === 'intermediate').length;
const expiredCount = data.certs.filter((c) => c.validity.state === 'expired').length;
const orphanCount = data.certs.filter((c) => c.orphan).length;
// Status chips only earn their space when there is something to filter out.
const showStatusChips = expiredCount > 0 || orphanCount > 0;

// About-panel facts. Only rows whose data exists are included (filtered here
// and again defensively by the shared component).
const aboutFacts = [
  data.model && {
    label: 'Model',
    value: data.model === 'accredited-tsl' ? 'Accredited CAs (ETSI Trusted List)' : 'National hierarchy',
  },
  data.governingLaw && { label: 'Governing law', value: data.governingLaw },
  data.technology?.keyAlgorithms?.length > 0 && {
    label: 'Key algorithms',
    value: data.technology.keyAlgorithms.join(', '),
  },
  data.technology?.signatureStandards?.length > 0 && {
    label: 'Signature standards',
    value: data.technology.signatureStandards.join(', '),
  },
  data.revocation?.snapshotExpiresAt && {
    label: 'Revocation snapshot',
    value: `current, refresh due ${fmtDate(data.revocation.snapshotExpiresAt)}`,
  },
].filter(Boolean);
---
<BaseLayout
  title={`${getCountryName(data.code, lang)} ${t.cardIssuer}s`}
  description={t.countryHierarchyAria.replace('{0}', getCountryName(data.code, lang)) + `: ${data.count} trust anchors published by ${data.authority?.name}.`}
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={`${base}/`}>{t.countryNavHome}</a></li>
      <li aria-current="page">{getCountryName(data.code, lang)}</li>
    </ol>
  </nav>

  <header class="country-head">
    <div class="country-head__title">
      <span class="country-head__flag" aria-hidden="true">{data.flag}</span>
      <div>
        <h1>{getCountryName(data.code, lang)}</h1>
        <p class="country-head__authority">
          {t.countryPublishedBy} {data.authority?.url
            ? <a href={data.authority?.url} rel="noopener noreferrer" target="_blank" title={`${data.authority?.name} (official site, opens in a new tab)`}>{data.authority?.name}</a>
            : data.authority?.name}
        </p>
      </div>
    </div>
    <dl class="country-head__stats">
      <div><dt>{t.countryCertsStat}</dt><dd>{data.count}</dd></div>
      <div><dt>{t.countryRootsStat}</dt><dd>{rootCount}</dd></div>
      <div><dt>{t.countryIntermediatesStat}</dt><dd>{intermediateCount}</dd></div>
      <div><dt>{t.countryUpdatedStat}</dt><dd><time datetime={data.generatedAt}>{fmtDate(data.generatedAt)}</time></dd></div>
    </dl>
  </header>

  <AboutPanel
    ariaLabel="About this PKI"
    notes={data.notes}
    facts={aboutFacts}
    capabilities={data.capabilities}
    capabilitiesLabel="Capabilities"
    links={data.relatedLinks}
    linksLabel="Related official resources"
    newTabHint="opens in a new tab"
  />

  <div data-filter-scope>
    <div class="filter">
      <label class="visually-hidden" for="cert-search">{t.countrySearchLabel}</label>
      <input
        id="cert-search"
        type="search"
        class="filter__input"
        placeholder={t.countrySearchPlaceholder}
        autocomplete="off"
        aria-controls="ca-tree"
        data-filter-input
        data-filter-hide-closest=".tree-node"
        data-filter-status-template={t.countryFilterStatus}
      />
      <p class="filter__status" data-filter-status role="status" aria-live="polite"></p>
    </div>

    {showStatusChips && (
      <div class="cert-filters">
        <div class="cert-filters__chips" role="group" aria-label={t.filterChipsAria}>
          <button type="button" class="cert-chip" data-filter-chip data-chip-value="current" data-chip-default={expiredCount > 0 ? true : undefined}>{t.filterChipCurrent}</button>
          {expiredCount > 0 && (
            <button type="button" class="cert-chip" data-filter-chip data-chip-value="expired">{t.filterChipExpired} <span class="cert-chip__n">{expiredCount}</span></button>
          )}
          {orphanCount > 0 && (
            <button type="button" class="cert-chip" data-filter-chip data-chip-value="unchained">{t.filterChipUnchained} <span class="cert-chip__n">{orphanCount}</span></button>
          )}
          <button type="button" class="cert-chip" data-filter-chip data-chip-value="all" data-chip-default={expiredCount === 0 ? true : undefined}>{t.filterChipAll}</button>
        </div>
        {expiredCount > 0 && <p class="cert-filters__hint">{t.filterChipsHint}</p>}
      </div>
    )}

    <section aria-label={t.countryHierarchyAria.replace('{0}', getCountryName(data.code, lang))}>
      <ul class="tree" id="ca-tree" role="tree">
        {data.roots.map((root) => <TreeNode cert={root} code={data.code} depth={0} />)}
      </ul>
      <p class="no-results" data-filter-empty hidden>{t.countryNoResults}</p>
    </section>
  </div>
</BaseLayout>

<style>
  .country-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-5);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }
  .country-head__title { display: flex; gap: var(--space-4); align-items: center; }
  .country-head__flag { font-size: 2.75rem; line-height: 1; }
  .country-head h1 { margin: 0; }
  .country-head__authority { margin: var(--space-1) 0 0; color: var(--color-text-muted); font-size: var(--text-sm); max-width: 62ch; line-height: 1.45; overflow-wrap: anywhere; }
  .country-head__stats {
    display: flex;
    gap: var(--space-5);
    margin: 0;
    flex-wrap: wrap;
  }
  .country-head__stats div { text-align: right; }
  .country-head__stats dt { font-size: var(--text-xs); color: var(--color-text-subtle); text-transform: uppercase; letter-spacing: 0.05em; }
  .country-head__stats dd { margin: 0; font-size: var(--text-xl); font-weight: 700; }

  .filter { margin-bottom: var(--space-6); }
  .filter__input {
    width: 100%;
    max-width: 34rem;
    font-size: var(--text-base);
    font-family: var(--font-sans);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text);
  }
  .filter__input:focus-visible { box-shadow: var(--focus-ring); border-color: var(--color-accent); }
  .filter__status { margin: var(--space-2) 0 0; font-size: var(--text-sm); color: var(--color-text-muted); }

  .cert-filters { margin: 0 0 var(--space-6); }
  .cert-filters__chips { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .cert-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
  }
  .cert-chip:hover { color: var(--color-text); border-color: var(--color-text-subtle); }
  .cert-chip[aria-pressed='true'] {
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent-light);
  }
  .cert-chip__n {
    font-variant-numeric: tabular-nums;
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }
  .cert-chip[aria-pressed='true'] .cert-chip__n { color: var(--color-accent-light); }
  .cert-filters__hint { margin: var(--space-2) 0 0; font-size: var(--text-xs); color: var(--color-text-subtle); }

  .tree { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-4); }
  .no-results { color: var(--color-text-muted); }

  @media (max-width: 640px) {
    .country-head__stats { gap: var(--space-4); }
    .country-head__stats div { text-align: left; }
  }
</style>
