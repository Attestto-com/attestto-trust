---
import BaseLayout from '../layouts/BaseLayout.astro';
import CountryTable from '../components/CountryTable.astro';
import { loadAllCountries } from '../lib/trust.js';
import { TRANSLATIONS } from '../lib/i18n.js';

const countries = loadAllCountries();
const totalCountries = countries.length;
const totalCerts = countries.reduce((sum, c) => sum + (c.count || 0), 0);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const lang = 'en';
const t = TRANSLATIONS[lang];
---
<BaseLayout
  title={t.homeTitle}
  description={t.siteDesc}
>
  <section class="intro">
    <div class="intro__text">
      <h1>{t.homeH1}</h1>
      <p class="lede" set:html={t.homeLede} />
    </div>
    <dl class="intro__stats" aria-label={`${totalCountries} ${t.homeCountriesH2}, ${totalCerts} ${t.countryCertsStat}`}>
      <div><dt>{t.homeCountriesH2}</dt><dd>{totalCountries}</dd></div>
      <div><dt>{t.countryCertsStat}</dt><dd>{totalCerts.toLocaleString(lang)}</dd></div>
    </dl>
  </section>

  <section id="countries" aria-labelledby="countries-h">
    <h2 id="countries-h">{t.homeCountriesH2}</h2>
    <CountryTable countries={countries} lang={lang} base={base} t={t} />
  </section>

  <section id="developers" class="developers" aria-labelledby="dev-h">
    <h2 id="dev-h">{t.homeDevsH2}</h2>
    <p set:html={t.homeDevsIntro} />
    <div class="dev-grid">
      <div class="dev-card">
        <h3>{t.homeNpmH3}</h3>
        <p class="dev-card__desc">{t.homeNpmDesc}</p>
        <pre class="mono"><code>npm install @attestto/trust</code></pre>
        <a class="btn" href="https://www.npmjs.com/package/@attestto/trust" rel="noopener noreferrer" target="_blank" title="@attestto/trust on npm (opens in a new tab)">{t.homeNpmBtn}</a>
      </div>
      <div class="dev-card">
        <h3>{t.homeResolverH3}</h3>
        <p class="dev-card__desc">{t.homeResolverDesc}</p>
        <a class="btn" href="https://github.com/Attestto-com/attestto-did-resolver" rel="noopener noreferrer" target="_blank" title="did:pki resolver repository on GitHub (opens in a new tab)">{t.homeResolverBtn}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-bottom: var(--space-8);
  }
  .intro__text { max-width: 46rem; }
  .lede { font-size: var(--text-lg); color: var(--color-text-muted); }
  .intro__stats { display: flex; gap: var(--space-6); margin: 0; flex-shrink: 0; }
  .intro__stats div { text-align: right; }
  .intro__stats dt { font-size: var(--text-xs); color: var(--color-text-subtle); text-transform: uppercase; letter-spacing: 0.05em; }
  .intro__stats dd { margin: 0; font-size: var(--text-2xl); font-weight: 700; font-variant-numeric: tabular-nums; }
  @media (max-width: 640px) {
    .intro__stats { gap: var(--space-5); }
    .intro__stats div { text-align: left; }
  }

  .developers { margin-top: var(--space-10); }
  .dev-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-4);
  }
  .dev-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }
  .dev-card h3 { margin-top: 0; }
  .dev-card__desc { color: var(--color-text-muted); font-size: var(--text-sm); }
  .dev-card pre {
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-3);
    overflow-x: auto;
    margin: 0 0 var(--space-4);
  }
</style>
