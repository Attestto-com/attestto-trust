---
// Shared "About this PKI / About this anchor" panel.
// Layout is defined ONCE here and used by country pages and the GLEIF page,
// so a layout change lands in every consumer.
//
// Order: notes (on top) -> facts grid -> capabilities (optional) -> links.
const {
  facts = [],
  notes,
  capabilities = [],
  capabilitiesLabel = 'Capabilities',
  links = [],
  linksLabel = 'Related official resources',
  newTabHint = 'opens in a new tab',
  ariaLabel = 'About this PKI',
} = Astro.props;

const shownFacts = facts.filter((f) => f && f.value != null && f.value !== '');
const shownCaps = capabilities?.filter(Boolean) ?? [];
const shownLinks = links?.filter((l) => l && l.url) ?? [];
---
<section class="pki-about" aria-label={ariaLabel}>
  {notes && <p class="pki-about__notes">{notes}</p>}

  {shownFacts.length > 0 && (
    <dl class="pki-about__grid">
      {shownFacts.map((f) => (
        <div>
          <dt>{f.label}</dt>
          <dd>{f.mono ? <code>{f.value}</code> : f.value}</dd>
        </div>
      ))}
    </dl>
  )}

  {shownCaps.length > 0 && (
    <div class="pki-about__caps">
      <span class="pki-about__caplabel">{capabilitiesLabel}</span>
      {shownCaps.map((c) => <span class="chip">{c}</span>)}
    </div>
  )}

  {shownLinks.length > 0 && (
    <ul class="pki-about__links" aria-label={linksLabel}>
      {shownLinks.map((l) => (
        <li>
          <a
            href={l.url}
            rel="noopener noreferrer"
            target="_blank"
            title={`${l.label} (${newTabHint})`}
            aria-label={`${l.label} (${newTabHint})`}
          >{l.label} <span aria-hidden="true">↗</span></a>
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .pki-about {
    margin: var(--space-4) 0;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
  }
  /* Notes sit on top of the facts (the /gleif layout, now shared everywhere). */
  .pki-about__notes { margin: 0 0 var(--space-4); color: var(--color-text-muted); font-size: var(--text-sm); line-height: 1.5; }
  .pki-about__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: var(--space-3); margin: 0; }
  .pki-about__grid dt { font-size: var(--text-xs); color: var(--color-text-subtle); text-transform: uppercase; letter-spacing: 0.03em; }
  .pki-about__grid dd { margin: 2px 0 0; font-size: var(--text-sm); font-weight: 600; }
  /* Monospace values (AID / fingerprint) wrap instead of overflowing. */
  .pki-about__grid dd code { font-size: var(--text-xs); word-break: break-all; font-weight: 400; }
  .pki-about__caps { margin-top: var(--space-3); display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); }
  .pki-about__caplabel { font-size: var(--text-xs); color: var(--color-text-subtle); text-transform: uppercase; letter-spacing: 0.03em; }
  .chip { display: inline-block; padding: 2px 10px; border-radius: 999px; background: var(--color-highlight-soft); color: var(--color-highlight); font-size: var(--text-xs); font-weight: 600; }
  .pki-about__links { margin: var(--space-3) 0 0; padding: 0; list-style: none; display: flex; flex-wrap: wrap; gap: var(--space-3); }
  .pki-about__links a { font-size: var(--text-sm); }
</style>
