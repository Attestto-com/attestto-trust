---
import RoleBadge from './RoleBadge.astro';
import ValidityChip from './ValidityChip.astro';
import CopyValue from './CopyValue.astro';
import { truncateMid, pemHref } from '../lib/trust.js';
import { TRANSLATIONS } from '../lib/i18n.js';

const { cert, code } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const lang = Astro.currentLocale === 'es' ? 'es' : 'en';
const t = TRANSLATIONS[lang];

const detailHref = lang === 'es' ? `${base}/es/${code}/${cert.slug}` : `${base}/${code}/${cert.slug}`;
const fmt = (iso) =>
  new Date(iso).toLocaleDateString(lang === 'es' ? 'es-ES' : 'en-CA', { year: 'numeric', month: 'short', day: '2-digit' });
---
<article
  class="cert-card"
  data-search={`${cert.subjectDisplay} ${cert.issuerDisplay} ${cert.serialNumber} ${cert.sha256} ${cert.role}`.toLowerCase()}
>
  <header class="cert-card__head">
    <h3 class="cert-card__title">
      <a href={detailHref}>{cert.subjectDisplay}</a>
    </h3>
    <div class="cert-card__badges">
      <RoleBadge role={cert.role} />
      <ValidityChip validity={cert.validity} />
    </div>
  </header>

  <dl class="cert-card__meta">
    <div>
      <dt>{t.cardIssuer}</dt>
      <dd>{cert.issuer === cert.subject ? t.cardSelfSigned : cert.issuerDisplay}</dd>
    </div>
    <div>
      <dt>{t.cardValid}</dt>
      <dd><time datetime={cert.validFrom}>{fmt(cert.validFrom)}</time> {t.cardTo}
        <time datetime={cert.validTo}>{fmt(cert.validTo)}</time></dd>
    </div>
    <div>
      <dt>{t.cardSerial}</dt>
      <dd><code class="mono" title={cert.serialNumber}>{truncateMid(cert.serialNumber, 10, 6)}</code></dd>
    </div>
    <div>
      <dt>{t.cardSha256}</dt>
      <dd><CopyValue value={cert.sha256} label="SHA-256 fingerprint" truncate={true} /></dd>
    </div>
  </dl>

  {cert.orphan && (
    <p class="notice">
      {t.cardOrphanNotice.replace('{0}', cert.issuerDisplay)}
    </p>
  )}

  <footer class="cert-card__actions">
    <a class="btn" href={detailHref}>{t.cardDetails}</a>
    <a class="btn" href={pemHref(code, cert.file)} download>{t.cardDownloadPem}</a>
  </footer>
</article>

<style>
  .cert-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
  }
  .cert-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
  }
  .cert-card__title {
    font-size: var(--text-base);
    margin: 0;
    font-weight: 650;
    word-break: break-word;
  }
  .cert-card__badges {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .cert-card__meta {
    display: grid;
    gap: var(--space-2);
    margin: 0 0 var(--space-4);
  }
  .cert-card__meta div {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-3);
    align-items: baseline;
  }
  .cert-card__meta dt {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
  }
  .cert-card__meta dd {
    margin: 0;
    font-size: var(--text-sm);
    word-break: break-word;
  }
  .cert-card__actions {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  @media (max-width: 520px) {
    .cert-card__meta div { grid-template-columns: 1fr; gap: 0; }
  }
</style>
