---
import '../styles/global.css';
import { TRANSLATIONS } from '../lib/i18n.js';

const lang = Astro.currentLocale === 'es' ? 'es' : 'en';
const t = TRANSLATIONS[lang];

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const baseHref = lang === 'es' ? `${base}/es` : (base || '/');

const pageTitle = title ? `${title} · ${t.siteTitle}` : `${t.siteTitle} · ${t.homeTitle}`;
const desc = description || t.siteDesc;

// Calculate alternate language link
const currentPath = Astro.url.pathname;
const baseNormalized = base === '' ? '' : base;
let relativePath = currentPath;
if (baseNormalized && currentPath.startsWith(baseNormalized)) {
  relativePath = currentPath.slice(baseNormalized.length);
}
if (!relativePath.startsWith('/')) {
  relativePath = '/' + relativePath;
}

let altLangHref;
if (lang === 'es') {
  const stripped = relativePath.replace(/^\/es(\/|$)/, '$1');
  altLangHref = `${baseNormalized}${stripped === '' ? '/' : stripped}`;
} else {
  altLangHref = `${baseNormalized}/es${relativePath}`;
}
altLangHref = altLangHref.replace(/\/+/g, '/');

const countriesHref = lang === 'es' ? `${base}/es#countries` : `${base}/#countries`;
const devsHref = lang === 'es' ? `${base}/es#developers` : `${base}/#developers`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a0a14" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>

    <header class="site-header">
      <div class="container site-header__inner">
        <a class="brand" href={baseHref} title={t.siteTitle} aria-label={`${t.siteTitle} — ${lang === 'es' ? 'inicio' : 'home'}`}>
          <img class="brand__logo" src={`${base}/logo-full-white.svg`} alt="Attestto" width="113" height="28" />
          <span class="brand__sub">Trust Directory</span>
        </a>
        <nav class="site-nav" aria-label={lang === 'es' ? 'Principal' : 'Primary'}>
          <a href={countriesHref} title={t.navCountries}>{t.navCountries}</a>
          <a href={devsHref} title={t.navDevs}>{t.navDevs}</a>
          <a
            href={altLangHref}
            class="lang-switch"
            hreflang={lang === 'es' ? 'en' : 'es'}
            title={lang === 'es' ? 'View in English' : 'Ver en español'}
            aria-label={lang === 'es' ? 'Switch language to English' : 'Cambiar idioma a español'}
          >
            {lang === 'es' ? '🇺🇸 EN' : '🇪🇸 ES'}
          </a>
        </nav>
      </div>
    </header>

    <div class="mirror-banner" role="note">
      <div class="container mirror-banner__inner">
        <strong>{t.bannerText}</strong>{' '}
        {t.bannerSub}
      </div>
    </div>

    <main id="main" class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p set:html={t.footerLine1} />
        <p>{t.footerLine2}</p>
        <p set:html={t.footerLine3} />
        <nav class="footer-links" aria-label={lang === 'es' ? 'Enlaces del pie de página' : 'Footer links'}>
          <a href="https://github.com/Attestto-com/attestto-trust" rel="noopener noreferrer" target="_blank" title={lang === 'es' ? 'Repositorio attestto-trust en GitHub (abre en una pestaña nueva)' : 'attestto-trust repository on GitHub (opens in a new tab)'}>
            <svg class="footer-ico" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            <span>attestto-trust</span>
          </a>
          <a href="https://github.com/Attestto-com/attestto-did-resolver" rel="noopener noreferrer" target="_blank" title={lang === 'es' ? 'Repositorio del resolutor did:pki en GitHub (abre en una pestaña nueva)' : 'did:pki resolver repository on GitHub (opens in a new tab)'}>
            <svg class="footer-ico" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.6 7.6 0 012-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            <span>did:pki resolver</span>
          </a>
          <a href="https://attestto.com" rel="noopener noreferrer" target="_blank" title={lang === 'es' ? 'attestto.com (abre en una pestaña nueva)' : 'attestto.com (opens in a new tab)'}>attestto.com</a>
          <a href="https://attestto.org" rel="noopener noreferrer" target="_blank" title={lang === 'es' ? 'attestto.org (abre en una pestaña nueva)' : 'attestto.org (opens in a new tab)'}>attestto.org</a>
          <a href="https://discord.gg/F3AhFVarXz" rel="noopener noreferrer" target="_blank" title={lang === 'es' ? 'Comunidad de Attestto en Discord (abre en una pestaña nueva)' : 'Attestto community on Discord (opens in a new tab)'}>
            <svg class="footer-ico" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="currentColor"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1826 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg>
            <span>Discord</span>
          </a>
        </nav>
      </div>
    </footer>

    <script>
      import { initFilters } from '../scripts/filterable.js';
      initFilters();
    </script>

    <script define:vars={{ lang, copiedText: t.copySuccess }}>
      // Copy-to-clipboard for hashes/serials. Progressive enhancement only.
      document.addEventListener('click', async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const btn = target.closest('.copy');
        if (!(btn instanceof HTMLElement)) return;
        const value = btn.getAttribute('data-copy');
        if (!value) return;
        try {
          await navigator.clipboard.writeText(value);
          const original = btn.textContent;
          btn.textContent = copiedText;
          btn.setAttribute('data-copied', 'true');
          window.setTimeout(() => {
            btn.textContent = original;
            btn.removeAttribute('data-copied');
          }, 1400);
        } catch {
          /* clipboard unavailable; value is still visible in the code element */
        }
      });
    </script>
  </body>
</html>
