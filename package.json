{
  "name": "@attestto/trust",
  "version": "1.0.0",
  "description": "Independent public mirror of X.509 trust anchors for national digital signature infrastructures. Currently: Costa Rica (BCCR / SINPE / MICITT Firma Digital), Brazil (ICP-Brasil).",
  "homepage": "https://attestto.org",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./cr": "./countries/cr/index.js",
    "./cr/pems/*": "./countries/cr/current/*.pem",
    "./br": "./countries/br/index.js",
    "./br/pems/*": "./countries/br/current/*.pem",
    "./ar": "./countries/ar/index.js",
    "./ar/pems/*": "./countries/ar/current/*.pem"
  },
  "files": [
    "index.js",
    "countries/*/index.js",
    "countries/*/current/*.pem",
    "countries/*/current/manifest.json"
  ],
  "scripts": {
    "generate": "node scripts/generate-exports.mjs",
    "test": "node --test tests/"
  },
  "keywords": [
    "pki",
    "x509",
    "trust-anchors",
    "costa-rica",
    "firma-digital",
    "bccr",
    "sinpe",
    "brazil",
    "icp-brasil"
  ],
  "author": "Attestto <hello@attestto.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Attestto-com/attestto-trust.git"
  }
}
